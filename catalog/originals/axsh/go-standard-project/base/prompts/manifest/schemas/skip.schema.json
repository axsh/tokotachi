{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "skip.schema.json",
  "title": "Skip Definition",
  "description": "Schema for skip entities (not deployed to targets).",
  "type": "object",
  "required": ["apiVersion", "kind", "id", "title"],
  "properties": {
    "apiVersion": { "type": "string", "const": "agent.meta/v1" },
    "kind": { "type": "string", "const": "skip" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "title": { "type": "string" },
    "scope": {
      "type": "string",
      "enum": ["project", "path", "module"]
    },
    "activation": {
      "type": "object",
      "properties": {
        "mode": { "type": "string" }
      },
      "additionalProperties": false
    },
    "body": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
