#!/usr/bin/env bash
# Launch development environment for a feature.
# Wrapper around devctl up.
# Usage: ./scripts/dist/dev <feature-name> [args...]
# Example: ./scripts/dist/dev devctl

set -euo pipefail
source "$(dirname "${BASH_SOURCE[0]}")/_lib.sh"

# ─── Argument check ─────────────────────────────────────────────────
if [[ $# -lt 1 ]]; then
  echo "Usage: $0 <feature-name> [args...]"
  echo "Example: $0 devctl"
  exit 1
fi

FEATURE_NAME="$1"
shift

# ─── Ensure devctl is installed ─────────────────────────────────────
NATIVE_OS="$(detect_os)"
DEVCTL="${REPO_ROOT}/bin/devctl"
[[ "$NATIVE_OS" == "windows" ]] && DEVCTL="${DEVCTL}.exe"

if [[ ! -x "$DEVCTL" ]]; then
  warn "devctl not found in bin/. Installing..."
  "${SCRIPT_DIR}/install-tools" devctl
fi

if [[ ! -x "$DEVCTL" ]]; then
  fail "Failed to install devctl"
  exit 1
fi

# ─── Launch development environment ─────────────────────────────────
info "Starting development environment for ${FEATURE_NAME}..."
exec "$DEVCTL" up "$FEATURE_NAME" "$@"
