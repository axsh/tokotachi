{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "procedure.schema.json",
  "title": "Procedure Definition",
  "description": "Schema for agent procedure (workflow) definitions in the manifest system.",
  "type": "object",
  "required": ["apiVersion", "kind", "id", "title", "trigger"],
  "properties": {
    "apiVersion": { "type": "string", "const": "agent.meta/v1" },
    "kind": { "type": "string", "const": "procedure" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Globally unique kebab-case identifier."
    },
    "title": { "type": "string", "description": "Human-readable title." },
    "trigger": {
      "type": "object",
      "properties": {
        "command": {
          "type": "string",
          "description": "Slash command name that triggers this procedure."
        },
        "manual_only": {
          "type": "boolean",
          "default": false,
          "description": "If true, procedure can only be invoked manually."
        }
      },
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ordered list of step identifiers."
    },
    "body": {
      "type": "string",
      "description": "Inline procedure body text."
    },
    "uses_capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of capabilities used by this procedure."
    },
    "arguments": {
      "type": "object",
      "description": "Input arguments for the procedure."
    },
    "side_effects": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Side effects produced by this procedure."
    },
    "approval": {
      "type": "object",
      "description": "Approval requirements for this procedure.",
      "properties": {
        "human_required_for": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "oneOf": [
    { "required": ["steps"] },
    { "required": ["body"] }
  ],
  "additionalProperties": false
}
