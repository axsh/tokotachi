{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intake-event.schema.json",
  "title": "Intake Event",
  "description": "Full stored event schema including auto-supplemented fields",
  "type": "object",
  "required": [
    "version", "source_type", "agent", "task_summary", "raw_notes",
    "event_id", "instance_id", "content_hash", "content_id",
    "scope", "timestamps", "provenance"
  ],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "source_type": { "type": "string", "enum": ["coding_agent"] },
    "agent": {
      "type": "string",
      "enum": ["codex", "claude-code", "antigravity", "cursor", "unknown"]
    },
    "task_summary": { "type": "string", "minLength": 1, "maxLength": 500 },
    "raw_notes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    },
    "changed_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "flags": {
      "type": "object",
      "properties": {
        "architecture_impact": { "type": "boolean" },
        "memory_related": { "type": "boolean" },
        "prompt_related": { "type": "boolean" },
        "agent_behavior_related": { "type": "boolean" },
        "requires_immediate_action": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "client_request_id": { "type": "string" },
    "context": {
      "type": "object",
      "properties": {
        "session_id": { "type": "string" },
        "task_id": { "type": "string" },
        "wrapper_version": { "type": "string" }
      }
    },
    "extra": { "type": "object" },
    "event_id": {
      "type": "string",
      "pattern": "^E-[0-9A-Z]{26}$"
    },
    "instance_id": { "type": "string" },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "content_id": {
      "type": "string",
      "pattern": "^RAWC-[0-9a-f]{64}$"
    },
    "git": {
      "type": "object",
      "properties": {
        "branch": { "type": "string" },
        "head_commit": { "type": "string" },
        "is_dirty": { "type": "boolean" },
        "merge_base": { "type": "string" },
        "default_branch": { "type": "string" }
      }
    },
    "scope": {
      "type": "string",
      "enum": ["branch", "session"]
    },
    "branch_package": { "type": "string" },
    "effective_changed_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "timestamps": {
      "type": "object",
      "required": ["created_at", "stored_at"],
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "stored_at": { "type": "string", "format": "date-time" }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["hostname", "user", "cwd"],
      "properties": {
        "hostname": { "type": "string" },
        "user": { "type": "string" },
        "cwd": { "type": "string" },
        "wrapper_version": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
