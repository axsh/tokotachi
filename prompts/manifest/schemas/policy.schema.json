{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "policy.schema.json",
  "title": "Policy Definition",
  "description": "Schema for agent policy definitions in the manifest system.",
  "type": "object",
  "required": ["apiVersion", "kind", "id", "title", "scope", "activation", "body"],
  "properties": {
    "apiVersion": { "type": "string", "const": "agent.meta/v1" },
    "kind": { "type": "string", "const": "policy" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Globally unique kebab-case identifier."
    },
    "title": { "type": "string", "description": "Human-readable title." },
    "scope": {
      "type": "string",
      "enum": ["project", "path", "module"],
      "description": "Scope of policy application."
    },
    "activation": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["always", "trigger", "manual"],
          "description": "Activation mode for the policy."
        }
      },
      "additionalProperties": false
    },
    "body": {
      "type": "string",
      "description": "Inline policy body text."
    },
    "paths": {
      "type": "array",
      "items": { "type": "string" },
      "description": "File path patterns this policy applies to."
    },
    "owners": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ownership teams or roles."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Classification tags."
    },
    "priority": {
      "type": "integer",
      "description": "Priority order (higher = more important)."
    },
    "targets": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Target tool IDs this policy applies to."
    },
    "applies_when": {
      "type": "string",
      "description": "Human-readable description of when this policy applies."
    }
  },
  "additionalProperties": false
}
