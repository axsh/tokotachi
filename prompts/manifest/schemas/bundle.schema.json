{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "bundle.schema.json",
  "title": "Bundle Definition",
  "type": "object",
  "required": ["apiVersion", "kind", "id", "title", "includes"],
  "properties": {
    "apiVersion": { "type": "string", "const": "agent.meta/v1" },
    "kind": { "type": "string", "const": "bundle" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "includes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
